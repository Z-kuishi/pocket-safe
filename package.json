{
  "name": "pocket-safe",
  "version": "1.0.0",
  "description": "🔐 口袋保险箱 - 让加密像拖拽一样简单",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "你的名字",
  "license": "MIT",
  "build": {
    "appId": "com.yourname.pocketsafe",
    "productName": "口袋保险箱",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "口袋保险箱"
    },
    "files": [
      "main.js",
      "delete_file.py",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/.bin"
    ]
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "electron": "^40.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "archiver": "^5.3.0",
    "unzipper": "^0.10.11"
  }
}
